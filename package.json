{
  "name": "opencode-plugin-goal",
  "version": "0.1.0",
  "description": "Persistent /goal workflows for OpenCode.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "goal",
    "agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.39"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "engines": {
    "opencode": ">=0.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "bun --check src/index.ts",
    "prepublishOnly": "bun run check",
    "pack:dry": "npm pack --dry-run"
  }
}
